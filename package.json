{
  "name": "refund-support-agent",
  "version": "0.1.0",
  "private": true,
  "description": "LLM customer-support agent that approves, denies, or escalates e-commerce refunds against a written policy",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "seed": "tsx scripts/seed-db.ts",
    "gen:data": "tsx scripts/generate-synthetic-data.ts",
    "gen:policy": "tsx scripts/generate-policy.ts",
    "stress": "tsx scripts/stress.ts"
  },
  "dependencies": {
    "@langchain/anthropic": "^1.4.0",
    "@langchain/core": "^1.1.48",
    "@langchain/langgraph": "^1.3.6",
    "@langchain/openai": "^1.4.7",
    "better-sqlite3": "^12.10.0",
    "langsmith": "^0.7.5",
    "next": "^16.2.7",
    "pino": "^10.3.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.0",
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "pino-pretty": "^13.0.0",
    "sass": "^1.83.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
