{
  "name": "refund-support-agent",
  "version": "0.1.0",
  "private": true,
  "description": "LLM customer-support agent that approves, denies, or escalates e-commerce refunds against a written policy",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "seed": "tsx scripts/seed-db.ts",
    "smoke": "tsx scripts/smoke.ts",
    "gen:data": "tsx scripts/generate-synthetic-data.ts",
    "gen:policy": "tsx scripts/generate-policy.ts",
    "stress": "tsx scripts/stress.ts",
    "eval": "tsx scripts/eval-langsmith.ts"
  },
  "dependencies": {
    "@langchain/anthropic": "^1.4.0",
    "@langchain/core": "^1.1.48",
    "@langchain/langgraph": "^1.3.6",
    "@langchain/openai": "^1.4.7",
    "better-sqlite3": "^12.10.0",
    "jose": "^6.2.3",
    "langsmith": "^0.7.5",
    "next": "^16.2.7",
    "pino": "^10.3.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@next/eslint-plugin-next": "^16.2.7",
    "@playwright/test": "^1.50.0",
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "pino-pretty": "^13.0.0",
    "prettier": "^3.8.3",
    "sass": "^1.83.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.60.1",
    "vitest": "^3.0.0"
  }
}
