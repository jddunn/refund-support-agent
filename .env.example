# Provide at least one model provider key. The agent uses whichever is present
# (Anthropic first, then OpenAI). This is the only configuration the app needs.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Optional. Override the model used for the decision loop.
#   Anthropic: claude-sonnet-4-6 (default), claude-opus-4-8
#   OpenAI:    gpt-4.1, gpt-4o
# AGENT_MODEL=

# Optional. Hosted tracing and evals through LangSmith. Leave blank to run
# fully self-contained; the local admin dashboard records traces either way.
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=
# LANGSMITH_PROJECT=refund-support-agent

# Optional. Inject faults to exercise the recovery paths. Comma-separated:
#   tool_timeout, llm_malformed, provider_500, rate_limit, db_locked
# FAULT_INJECT=
