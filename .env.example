# ─────────────────────────────────────────────────────────────────────────────
# Configuration. Copy this file to `.env` and fill in a model key:
#   cp .env.example .env
# `.env` is gitignored and never committed. This file (.env.example) is the
# tracked template and holds no real values.
# ─────────────────────────────────────────────────────────────────────────────

# ── Model provider (required: at least one) ──────────────────────────────────
# The agent picks a provider by which key is present, in this order:
# Anthropic, then OpenAI, then OpenRouter. Set whichever you have.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# OpenRouter reaches many models (Anthropic, OpenAI, Google, Meta, ...) through
# one key, and powers the "OpenRouter Auto" option in the model selector.
OPENROUTER_API_KEY=

# ── Model selection (optional) ───────────────────────────────────────────────
# Force a model for the decision loop, overriding the UI selector and the AUTO
# router. Examples:
#   claude-sonnet-4-6   Anthropic, the default
#   claude-opus-4-8     Anthropic, strongest
#   gpt-4.1             OpenAI
#   openrouter/auto     let OpenRouter choose
# AGENT_MODEL=

# ── Hosted tracing and evals (optional) ──────────────────────────────────────
# LangSmith records full traces and powers `npm run eval`. Leave blank to run
# self-contained; the local admin dashboard records traces either way.
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=
# LANGSMITH_PROJECT=refund-support-agent

# ── Failure testing (optional) ───────────────────────────────────────────────
# Inject faults to exercise the recovery paths. Comma-separated:
#   tool_timeout, llm_malformed, provider_500, rate_limit, db_locked
# FAULT_INJECT=

# ── Server (optional) ────────────────────────────────────────────────────────
# Port the server listens on (default 3000). Docker reads this too.
# PORT=3000
